# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# ── API ────────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Neo4j (Topology Graph DB) ───────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── InfluxDB (Time-Series DB) ───────────────────────────────────────────────────
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=changeme
INFLUXDB_ORG=kai-ndt
INFLUXDB_BUCKET=5g-telemetry

# ── Kafka (Message Broker) ──────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=ndt-consumer

# ── Authentication (stub) ───────────────────────────────────────────────────────
# Replace with real JWT secret / OIDC settings in production
JWT_SECRET=changeme-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
